import React, { useState, useEffect, useRef } from 'react';
import { MessageCircle, Send, X, Bot, User, Minimize2, Maximize2 } from 'lucide-react';
import { Button } from './ui/button';
import { Input } from './ui/input';
import { ScrollArea } from './ui/scroll-area';
import { Badge } from './ui/badge';
import { Card, CardContent, CardHeader, CardTitle } from './ui/card';
import { useAuth } from '../context/AuthContext';
import { 
  createChatSession, 
  processChatMessage, 
  getChatHistory,
  processChatLead,
  updateChatSessionUserInfo
} from '../lib/openai';

const Chatbot = () => {
  const [isOpen, setIsOpen] = useState(false);
  const [isMinimized, setIsMinimized] = useState(false);
  const [messages, setMessages] = useState([]);
  const [inputMessage, setInputMessage] = useState('');
  const [isLoading, setIsLoading] = useState(false);
  const [sessionId, setSessionId] = useState(null);
  const [hasNewMessage, setHasNewMessage] = useState(false);
  const [userInfo, setUserInfo] = useState({ name: '', email: '', phone: '' });
  const [isCollectingInfo, setIsCollectingInfo] = useState(false);
  const [infoStep, setInfoStep] = useState(0); // 0: name, 1: email, 2: phone (optional)
  const [hasCollectedInfo, setHasCollectedInfo] = useState(false);
  const messagesEndRef = useRef(null);
  const { user } = useAuth();

  // Initialize chat session
  useEffect(() => {
    if (isOpen && !sessionId) {
      initializeChatSession();
    }
  }, [isOpen]);

  // Scroll to bottom when new messages arrive
  useEffect(() => {
    scrollToBottom();
  }, [messages]);

  // Show notification when chatbot is closed and new message arrives
  useEffect(() => {
    if (!isOpen && messages.length > 0) {
      const lastMessage = messages[messages.length - 1];
      if (lastMessage.sender === 'assistant') {
        setHasNewMessage(true);
      }
    }
  }, [messages, isOpen]);

  const initializeChatSession = async () => {
    try {
      const userEmail = user?.email || null;
      const session = await createChatSession(userEmail);
      if (session) {
        setSessionId(session.id);
        // Load chat history if exists
        const history = await getChatHistory(session.id);
        if (history.length > 0) {
          const formattedHistory = history.map(msg => ({
            id: Date.now() + Math.random(),
            text: msg.message,
            sender: msg.sender_type,
            timestamp: new Date(msg.created_at)
          }));
          setMessages(formattedHistory);
          // Check if user info was already collected
          const hasUserInfo = history.some(msg => 
            msg.sender_type === 'user' && msg.message.includes('@')
          );
          setHasCollectedInfo(hasUserInfo);
        } else {
          // Start with info collection for new sessions
          if (!user?.email) {
            setIsCollectingInfo(true);
            setInfoStep(0);
            setMessages([{
              id: Date.now(),
              text: "Welcome to Tailored Hands! 👋 I'm here to help you find the perfect pieces and answer any questions you have.\n\nTo provide you with the best personalized service, I'll need to get some quick information from you first.\n\nWhat's your name?",
              sender: 'assistant',
              timestamp: new Date()
            }]);
          } else {
            // If user is logged in, we already have their info
            setHasCollectedInfo(true);
            setUserInfo({ 
              name: user.profile?.full_name || 'Valued Customer',
              email: user.email,
              phone: user.profile?.phone || ''
            });
            setMessages([{
              id: Date.now(),
              text: `Welcome back, ${user.profile?.full_name || 'Valued Customer'}! 👋 I'm here to help you with any questions about our bespoke tailoring and fashion services.\n\nHow can I assist you today?`,
              sender: 'assistant',
              timestamp: new Date()
            }]);
          }
        }
      }
    } catch (error) {
      console.error('Error initializing chat session:', error);
    }
  };

  const scrollToBottom = () => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  };

  const handleUserInfoCollection = async (message) => {
    const trimmedMessage = message.trim();
    
    if (infoStep === 0) {
      // Collecting name
      if (trimmedMessage.length < 2) {
        const errorMessage = {
          id: Date.now() + 1,
          text: "Please enter a valid name (at least 2 characters).",
          sender: 'assistant',
          timestamp: new Date()
        };
        setMessages(prev => [...prev, errorMessage]);
        return;
      }
      
      setUserInfo(prev => ({ ...prev, name: trimmedMessage }));
      setInfoStep(1);
      
      const nextMessage = {
        id: Date.now() + 1,
        text: `Nice to meet you, ${trimmedMessage}! 😊\n\nNow, could you please share your email address? This will help me provide you with personalized recommendations and follow up on any questions you might have.`,
        sender: 'assistant',
        timestamp: new Date()
      };
      setMessages(prev => [...prev, nextMessage]);
      
    } else if (infoStep === 1) {
      // Collecting email
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(trimmedMessage)) {
        const errorMessage = {
          id: Date.now() + 1,
          text: "Please enter a valid email address (e.g., john@example.com).",
          sender: 'assistant',
          timestamp: new Date()
        };
        setMessages(prev => [...prev, errorMessage]);
        return;
      }
      
      setUserInfo(prev => ({ ...prev, email: trimmedMessage }));
      setInfoStep(2);
      
      const nextMessage = {
        id: Date.now() + 1,
        text: `Perfect! Thank you for sharing your email address.\n\nOne last optional question - would you like to share your phone number? This can help us assist you faster for urgent inquiries. You can also just type "skip" if you prefer not to share it.`,
        sender: 'assistant',
        timestamp: new Date()
      };
      setMessages(prev => [...prev, nextMessage]);
      
    } else if (infoStep === 2) {
      // Collecting phone (optional)
      const phoneRegex = /^[\+]?[1-9][\d]{3,14}$/;
      let phone = '';
      
      if (trimmedMessage.toLowerCase() !== 'skip') {
        const cleanedPhone = trimmedMessage.replace(/[^\d\+]/g, '');
        if (cleanedPhone.length > 0 && !phoneRegex.test(cleanedPhone)) {
          const errorMessage = {
            id: Date.now() + 1,
            text: "Please enter a valid phone number or type 'skip' to continue without it.",
            sender: 'assistant',
            timestamp: new Date()
          };
          setMessages(prev => [...prev, errorMessage]);
          return;
        }
        phone = cleanedPhone;
      }
      
      const finalUserInfo = {
        name: userInfo.name,
        email: userInfo.email,
        phone: phone
      };
      
      setUserInfo(finalUserInfo);
      setIsCollectingInfo(false);
      setHasCollectedInfo(true);
      
      // Save user info to session
      await updateChatSessionUserInfo(sessionId, finalUserInfo);
      
      const welcomeMessage = {
        id: Date.now() + 1,
        text: `Excellent! Thank you for sharing your information, ${finalUserInfo.name}! 🎉\n\nI now have everything I need to provide you with personalized assistance. I can help you with:\n\n• Custom tailoring and made-to-measure pieces\n• Ready-to-wear collections\n• Styling advice and recommendations\n• Order status and shipping information\n• Consultation bookings\n• And much more!\n\nWhat would you like to know about our services?`,
        sender: 'assistant',
        timestamp: new Date()
      };
      setMessages(prev => [...prev, welcomeMessage]);
    }
  };

  const handleSendMessage = async () => {
    if (!inputMessage.trim() || isLoading || !sessionId) return;

    // Client-side rate limiting (2 seconds between messages)
    const now = Date.now();
    const timeSinceLastMessage = now - (window.lastMessageTime || 0);
    
    if (timeSinceLastMessage < 2000) {
      const errorMessage = {
        id: Date.now() + 1,
        text: "Please wait a moment before sending another message.",
        sender: 'assistant',
        timestamp: new Date()
      };
      setMessages(prev => [...prev, errorMessage]);
      return;
    }

    // Check message length
    if (inputMessage.length > 1000) {
      const errorMessage = {
        id: Date.now() + 1,
        text: "Your message is too long. Please keep it under 1000 characters.",
        sender: 'assistant',
        timestamp: new Date()
      };
      setMessages(prev => [...prev, errorMessage]);
      return;
    }

    window.lastMessageTime = now;

    const userMessage = {
      id: Date.now(),
      text: inputMessage,
      sender: 'user',
      timestamp: new Date()
    };

    setMessages(prev => [...prev, userMessage]);
    const currentMessage = inputMessage;
    setInputMessage('');
    setIsLoading(true);

    try {
      // Handle user info collection
      if (isCollectingInfo) {
        await handleUserInfoCollection(currentMessage);
        setIsLoading(false);
        return;
      }

      // Normal chat processing
      const response = await processChatMessage(
        currentMessage, 
        sessionId, 
        user?.email || userInfo.email
      );

      const assistantMessage = {
        id: Date.now() + 1,
        text: response,
        sender: 'assistant',
        timestamp: new Date()
      };

      setMessages(prev => [...prev, assistantMessage]);
    } catch (error) {
      console.error('Error sending message:', error);
      
      // Check if it's a rate limit error
      if (error.message && error.message.includes('rate limit')) {
        const errorMessage = {
          id: Date.now() + 1,
          text: "You've sent too many messages. Please wait a moment before continuing.",
          sender: 'assistant',
          timestamp: new Date()
        };
        setMessages(prev => [...prev, errorMessage]);
      } else {
        const errorMessage = {
          id: Date.now() + 1,
          text: "I'm sorry, I'm having trouble responding right now. Please try again later.",
          sender: 'assistant',
          timestamp: new Date()
        };
        setMessages(prev => [...prev, errorMessage]);
      }
    } finally {
      setIsLoading(false);
    }
  };

  const handleKeyPress = (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      handleSendMessage();
    }
  };

  const toggleChat = async () => {
    console.log('🔄 toggleChat called', { 
      isOpen, 
      sessionId, 
      messageCount: messages.length,
      hasMessages: messages.length > 1,
      hasCollectedInfo,
      userInfo,
      willProcessLead: isOpen && sessionId && messages.length > 1 && hasCollectedInfo
    });

    // If closing the chat and we have a session with user info, process the lead
    if (isOpen && sessionId && messages.length > 1 && hasCollectedInfo) {
      console.log('🔄 Processing chat lead...', { 
        sessionId, 
        messageCount: messages.length,
        userInfo
      });
      
      // Show a small notification that lead is being processed
      const leadProcessingMessage = {
        id: Date.now() + 999,
        text: "💼 Thank you for chatting with us! We're saving your conversation so we can follow up with personalized recommendations...",
        sender: 'assistant',
        timestamp: new Date()
      };
      setMessages(prev => [...prev, leadProcessingMessage]);
      
      try {
        const result = await processChatLead(sessionId);
        console.log('✅ Chat lead processed successfully:', result);
        
        // Optional: Show success message
        setTimeout(() => {
          setMessages(prev => prev.filter(msg => msg.id !== leadProcessingMessage.id));
        }, 2000);
        
      } catch (error) {
        console.error('❌ Error processing chat lead:', error);
        console.error('❌ Full error details:', {
          message: error.message,
          stack: error.stack,
          sessionId,
          messageCount: messages.length,
          userInfo
        });
        
        // Remove the processing message even if there's an error
        setTimeout(() => {
          setMessages(prev => prev.filter(msg => msg.id !== leadProcessingMessage.id));
        }, 1000);
      }
    } else {
      console.log('ℹ️ Not processing lead because:', {
        isOpen: isOpen ? 'Chat is open' : 'Chat is not open',
        sessionId: sessionId ? 'Session exists' : 'No session',
        messageCount: messages.length > 1 ? `${messages.length} messages` : 'Not enough messages',
        hasCollectedInfo: hasCollectedInfo ? 'User info collected' : 'No user info collected'
      });
    }
    
    setIsOpen(!isOpen);
    if (!isOpen) {
      setHasNewMessage(false);
    }
  };

  const toggleMinimize = () => {
    setIsMinimized(!isMinimized);
  };

  const formatTime = (timestamp) => {
    return new Date(timestamp).toLocaleTimeString('en-US', {
      hour: '2-digit',
      minute: '2-digit'
    });
  };

  return (
    <>
      {/* Floating Chat Button */}
      <div className="fixed bottom-20 md:bottom-4 right-4 z-50">
        {!isOpen && (
          <Button
            onClick={toggleChat}
            className="relative w-14 h-14 rounded-full bg-gradient-to-br from-[#D2B48C] to-[#B8860B] hover:from-[#B8860B] hover:to-[#DAA520] shadow-xl transition-all duration-300 hover:scale-105 border-2 border-[#F5DEB3]/30"
            size="icon"
          >
            <MessageCircle className="w-6 h-6 text-white" />
            {hasNewMessage && (
              <div className="absolute -top-2 -right-2 w-5 h-5 bg-gradient-to-br from-orange-500 to-red-500 rounded-full flex items-center justify-center animate-pulse">
                <div className="w-2 h-2 bg-white rounded-full"></div>
              </div>
            )}
          </Button>
        )}
      </div>

      {/* Chat Interface */}
      {isOpen && (
        <div className="fixed bottom-20 md:bottom-4 right-4 z-50 w-80 sm:w-96 max-w-[calc(100vw-32px)] h-[500px] max-h-[calc(100vh-104px)] md:max-h-[calc(100vh-32px)]">
          <Card className="h-full flex flex-col shadow-2xl border-[#D2B48C]/20 bg-white overflow-hidden">
            {/* Header */}
            <CardHeader className="flex flex-row items-center justify-between p-4 bg-gradient-to-r from-[#1A1A1A] to-[#2A2A2A] text-white rounded-t-lg flex-shrink-0">
              <div className="flex items-center gap-3 min-w-0">
                <div className="w-8 h-8 bg-gradient-to-br from-[#D2B48C] to-[#B8860B] rounded-full flex items-center justify-center flex-shrink-0">
                  <Bot className="w-4 h-4 text-white" />
                </div>
                <div className="min-w-0 flex-1">
                  <CardTitle className="text-sm font-medium truncate">
                    Tailored Hands Assistant
                    {hasCollectedInfo && userInfo.name && (
                      <span className="text-xs text-gray-300 block">
                        Chatting with {userInfo.name}
                      </span>
                    )}
                  </CardTitle>
                  <p className="text-xs text-gray-300">
                    {isCollectingInfo ? 'Getting to know you...' : 'Online • Ready to help'}
                  </p>
                </div>
              </div>
              <div className="flex items-center gap-2 flex-shrink-0">
                <Button
                  variant="ghost"
                  size="sm"
                  onClick={toggleMinimize}
                  className="text-white hover:bg-white/10 p-1 h-auto rounded-full"
                >
                  {isMinimized ? <Maximize2 className="w-4 h-4" /> : <Minimize2 className="w-4 h-4" />}
                </Button>
                <Button
                  variant="ghost"
                  size="sm"
                  onClick={toggleChat}
                  className="text-white hover:bg-white/10 p-1 h-auto rounded-full"
                >
                  <X className="w-4 h-4" />
                </Button>
              </div>
            </CardHeader>

            {/* Messages Area */}
            {!isMinimized && (
              <CardContent className="flex-1 p-0 flex flex-col min-h-0">
                <div className="flex-1 overflow-hidden bg-gray-50/50">
                  <ScrollArea className="h-full">
                    <div className="p-4 space-y-4">
                      {messages.map((message) => (
                        <div
                          key={message.id}
                          className={`flex ${message.sender === 'user' ? 'justify-end' : 'justify-start'}`}
                        >
                          <div
                            className={`max-w-[75%] rounded-2xl px-4 py-3 ${
                              message.sender === 'user'
                                ? 'bg-gradient-to-br from-[#D2B48C] to-[#B8860B] text-white shadow-lg'
                                : 'bg-white text-gray-800 shadow-md border border-gray-200'
                            }`}
                          >
                            <div className="flex items-start gap-3">
                              {message.sender === 'assistant' && (
                                <div className="w-6 h-6 bg-gradient-to-br from-[#D2B48C] to-[#B8860B] rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                                  <Bot className="w-3 h-3 text-white" />
                                </div>
                              )}
                              {message.sender === 'user' && (
                                <div className="w-6 h-6 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                                  <User className="w-3 h-3 text-white" />
                                </div>
                              )}
                              <div className="min-w-0 flex-1">
                                <p className="text-sm leading-relaxed whitespace-pre-wrap break-words overflow-wrap-anywhere">
                                  {message.text}
                                </p>
                                <p className={`text-xs mt-2 ${
                                  message.sender === 'user' ? 'text-white/70' : 'text-gray-500'
                                }`}>
                                  {formatTime(message.timestamp)}
                                </p>
                              </div>
                            </div>
                          </div>
                        </div>
                      ))}
                      
                      {/* Loading indicator */}
                      {isLoading && (
                        <div className="flex justify-start">
                          <div className="bg-white text-gray-800 shadow-md border border-gray-200 rounded-2xl px-4 py-3 max-w-[75%]">
                            <div className="flex items-center gap-3">
                              <div className="w-6 h-6 bg-gradient-to-br from-[#D2B48C] to-[#B8860B] rounded-full flex items-center justify-center flex-shrink-0">
                                <Bot className="w-3 h-3 text-white" />
                              </div>
                              <div className="flex space-x-1">
                                <div className="w-2 h-2 bg-gray-400 rounded-full animate-bounce"></div>
                                <div className="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style={{ animationDelay: '0.1s' }}></div>
                                <div className="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style={{ animationDelay: '0.2s' }}></div>
                              </div>
                            </div>
                          </div>
                        </div>
                      )}
                      
                      <div ref={messagesEndRef} />
                    </div>
                  </ScrollArea>
                </div>

                {/* Input Area */}
                <div className="p-4 border-t border-gray-200 bg-white flex-shrink-0">
                  <div className="flex gap-2">
                    <Input
                      value={inputMessage}
                      onChange={(e) => setInputMessage(e.target.value)}
                      onKeyPress={handleKeyPress}
                      placeholder={
                        isCollectingInfo 
                          ? (infoStep === 0 ? "Enter your name..." : 
                             infoStep === 1 ? "Enter your email..." : 
                             "Enter your phone or type 'skip'...")
                          : "Type your message..."
                      }
                      disabled={isLoading}
                      className="flex-1 rounded-full border-gray-300 focus:border-[#D2B48C] focus:ring-[#D2B48C] px-4 py-2"
                    />
                    <Button
                      onClick={handleSendMessage}
                      disabled={!inputMessage.trim() || isLoading}
                      className="w-10 h-10 rounded-full bg-gradient-to-br from-[#D2B48C] to-[#B8860B] hover:from-[#B8860B] hover:to-[#DAA520] p-0 shadow-lg transition-all duration-200 hover:scale-105 flex-shrink-0"
                    >
                      <Send className="w-4 h-4 text-white" />
                    </Button>
                  </div>
                  <div className="flex items-center justify-between mt-2">
                    <p className="text-xs text-gray-500">
                      {isCollectingInfo ? 'Please provide the requested information' : 'Press Enter to send'}
                    </p>
                    <div className="flex items-center gap-1 text-xs text-gray-400">
                      <div className="w-2 h-2 bg-green-500 rounded-full"></div>
                      <span>Powered by OpenAI</span>
                    </div>
                  </div>
                </div>
              </CardContent>
            )}
          </Card>
        </div>
      )}
    </>
  );
};

export default Chatbot; 