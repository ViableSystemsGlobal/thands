# Hostinger Email Configuration
# Add these to your .env file

VITE_SMTP_HOST=mail.yourdomain.com
VITE_SMTP_PORT=587
VITE_SMTP_USERNAME=your@email.com
VITE_SMTP_PASSWORD=your_email_password
VITE_SMTP_FROM_EMAIL=noreply@yourdomain.com
VITE_SMTP_FROM_NAME=TailoredHands
VITE_SMTP_SECURE=true

# Instructions:
# 1. Replace 'yourdomain.com' with your actual domain
# 2. Replace 'your@email.com' with your Hostinger email address
# 3. Replace 'your_email_password' with your email account password
# 4. Add these variables to your .env file 